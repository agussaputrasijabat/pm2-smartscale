{
    "name": "pm2-smartscale",
    "version": "1.5.0",
    "description": "PM2 module to help dynamically scale applications based on utilization demand",
    "main": "dist/index.js",
    "dependencies": {
        "pidusage": "^4.0.1",
        "pm2": "^7.0.1",
        "pmx": "^1.6.8",
        "tslib": "^2.8.1"
    },
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "watch": "tsc -w -p tsconfig.json",
        "publish": "npm run build && npm publish"
    },
    "files": [
        "README.md",
        "dist/**/*.js"
    ],
    "apps": [
        {
            "merge_logs": true,
            "max_memory_restart": "256M",
            "script": "dist/index.js"
        }
    ],
    "config": {
        "scale_cpu_threshold": 70,
        "release_cpu_threshold": 30,
        "debug": false,
        "ignore_apps": "",
        "max_workers": "-1",
        "min_seconds_to_add_worker": 30,
        "min_seconds_to_release_worker": 180
    },
    "devDependencies": {
        "@types/node": "^22.19.21",
        "@types/pidusage": "^2.0.5",
        "typescript": "^6.0.3"
    },
    "engines": {
        "node": ">=18"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/agussaputrasijabat/pm2-smartscale.git"
    },
    "author": "Agus Saputra Sijabat (agus@eltechdigital.id)",
    "license": "MIT",
    "keywords": [
        "PM2",
        "Autoscale",
        "Configuration",
        "Scaling",
        "Scale",
        "Utilization",
        "Module"
    ]
}