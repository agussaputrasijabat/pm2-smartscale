{
    "compilerOptions": {
        "target": "ES2015",
        "module": "Node16",
        "lib": ["ES2017", "DOM"],
        // "moduleResolution": "Node",
        // TS 6 no longer auto-includes @types/* globally; declare node explicitly
        // so `node:os` / `node:child_process` builtins resolve via @types/node.
        "types": ["node"],
        "rootDir": "./",
        "outDir": "./dist",
        "allowSyntheticDefaultImports": true,
        "importHelpers": true,
        "alwaysStrict": true,
        "sourceMap": false,
        "forceConsistentCasingInFileNames": true,
        "noFallthroughCasesInSwitch": true,
        "noImplicitReturns": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noImplicitAny": false,
        "noImplicitThis": false,
        "strictNullChecks": false
    },
    "exclude": ["node_modules"]
}
